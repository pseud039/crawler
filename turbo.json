{
  "$schema": "https://turborepo.dev/schema.json",
  "ui":"tui",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "BLOB_PATH",
    "OPENAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs":["$TURBO_DEFAULT$",".env*"],
      "outputs": ["dist/**", "!dist/**/*.map"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}